---
import { Image } from "astro:assets";

import HeroImageDark from "~/assets/Dev-Docs-Header-Illustration-Dark-Mode-cropped.svg";
import HeroImageLight from "~/assets/Dev-Docs-Header-Illustration-Light-Mode-cropped.svg";

const heroImageAttrs = {
	loading: "eager" as const,
	decoding: "async" as const,
	width: 400,
	height: 400,
	alt: "Hero image",
};
---

<div
	class="flex flex-col-reverse items-center justify-center gap-8 md:flex-row"
>
	<div>
		<h1 class="text-5xl">Cloudflare Docs</h1>
		<p class="text-xl">Explore guides and tutorials for using Cloudflare.</p>
	</div>
	<div>
		<Image src={HeroImageDark} class="light:sl-hidden" {...heroImageAttrs} />
		<Image src={HeroImageLight} class="dark:sl-hidden" {...heroImageAttrs} />
	</div>
</div>
